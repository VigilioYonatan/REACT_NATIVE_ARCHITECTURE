{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "paths": {
      "@ecommerce/shared-types": ["./packages/shared-types/src/index.ts"],
      "@ecommerce/events": ["./packages/events/src/index.ts"],
      "@ecommerce/ui": ["./packages/ui/src/index.ts"],
      "@ecommerce/auth": ["./packages/auth/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
