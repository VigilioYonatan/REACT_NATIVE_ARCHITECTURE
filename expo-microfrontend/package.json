{
  "name": "expo-microfrontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "api": "json-server db.json --port 3001 --host 0.0.0.0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "biome:format": "pnpm exec biome format --write .",
    "biome:lint": "pnpm exec biome lint --write .",
    "biome:check": "pnpm exec biome check .",
    "lint": "expo lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.2.2",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "react-native": "0.83.1",
    "react-native-css-interop": "^0.2.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@callstack/repack": "^5.2.4",
    "@nx/expo": "^22.5.3",
    "@rspack/core": "^1.7.7",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "~19.2.13",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~10.0.0",
    "jest": "^30.2.0",
    "jest-expo": "^55.0.9",
    "jsdom": "^28.1.0",
    "json-server": "1.0.0-beta.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/src/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}
